# ─────────────────────────────────────────────────────────────────────────────
#  ENVIRONMENT VARIABLES
#  Copy this file to ".env.local" and fill in the values. .env.local is
#  git-ignored and never committed. See TRANSFER.md for the full handoff list.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — your Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# RECOMMENDED for production — hosted Postgres for the searchable red-flag DB.
# Get a free one at https://neon.tech (Create project → copy the connection
# string). Leave blank for local dev and the app falls back to a JSON file.
DATABASE_URL=

# OPTIONAL — Stripe (only needed once you turn on paid reads). See TRANSFER.md.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
